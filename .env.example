# GLM API (主模型)
ZHIPU_API_KEY=your_api_key_here
ZHIPU_MODEL=glm-4

# Embedding API (向量模型，如使用不同的API Key)
# 如果不设置，将使用 ZHIPU_API_KEY
ZHIPU_EMBEDDING_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-2

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=documents

# RAG参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
MAX_HISTORY=10

# API服务
API_HOST=0.0.0.0
API_PORT=8000
